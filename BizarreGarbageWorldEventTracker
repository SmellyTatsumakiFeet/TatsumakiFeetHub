-- Discord webhook function (Wave/Potassium compatible)
local function sendToDiscord(webhookUrl)
    if not webhookUrl or webhookUrl == "" then
        StatusLabel.Text = "Status: Error - No webhook URL!"
        if debugMode then debugPrint("Error: No webhook URL provided") end
        return false
    end
    
    -- Check if webhook URL is valid
    if not string.find(webhookUrl, "discord.com/api/webhooks/") then
        StatusLabel.Text = "Status: Invalid webhook URL!"
        if debugMode then debugPrint("Error: Invalid webhook URL -", webhookUrl) end
        return false
    end
    
    if debugMode then debugPrint("Attempting to send webhook to:", webhookUrl) end
    
    local data = {
        ["content"] = "@everyone A World Event Has Started!",
        ["username"] = "PudgeHub Event Tracker",
        ["avatar_url"] = "https://i.imgur.com/7Y7Y7Y7.png",
        ["embeds"] = {{
            ["title"] = "🌍 World Event Started!",
            ["description"] = "A world event has been detected. Head to Morioh Train Station to participate!",
            ["color"] = 16711680,
            ["timestamp"] = DateTime.now():ToIsoDate(),
            ["footer"] = {
                ["text"] = "PudgeHub v0.5 • Made by STF"
            }
        }}
    }
    
    -- Method 1: Standard HttpService (works in most executors)
    local success1, result1 = pcall(function()
        local jsonData = HttpService:JSONEncode(data)
        HttpService:PostAsync(webhookUrl, jsonData, Enum.HttpContentType.ApplicationJson)
        return true
    end)
    
    if success1 then
        StatusLabel.Text = "Status: Notification sent!"
        if debugMode then debugPrint("Webhook sent successfully using HttpService") end
        return true
    end
    
    if debugMode then debugPrint("HttpService method failed, trying syn.request...") end
    
    -- Method 2: syn.request (Wave/Potassium compatible)
    local success2, result2 = pcall(function()
        local request = syn and syn.request or http and http.request or request
        if not request then
            error("No request function found")
        end
        
        local response = request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(data)
        })
        
        if response and response.StatusCode == 204 then
            return true
        else
            return false, response
        end
    end)
    
    if success2 and result2 == true then
        StatusLabel.Text = "Status: Notification sent!"
        if debugMode then debugPrint("Webhook sent successfully using syn.request") end
        return true
    end
    
    -- Method 3: http.request (alternative)
    if debugMode then debugPrint("syn.request failed, trying http.request...") end
    
    local success3, result3 = pcall(function()
        if not http or not http.request then
            error("No http.request function found")
        end
        
        local response = http.request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(data)
        })
        
        return response and response.StatusCode == 204
    end)
    
    if success3 and result3 then
        StatusLabel.Text = "Status: Notification sent!"
        if debugMode then debugPrint("Webhook sent successfully using http.request") end
        return true
    end
    
    -- All methods failed
    StatusLabel.Text = "Status: Failed to send!"
    if debugMode then 
        debugPrint("All webhook methods failed!")
        debugPrint("HttpService error:", result1)
        debugPrint("syn.request error:", result2)
        debugPrint("http.request error:", result3)
    end
    return false
end

-- ========== ОСНОВНАЯ ЛОГИКА С ЗАЩИТОЙ ОТ СПАМА ==========

-- Переменные для отслеживания состояния события
local eventActive = false
local lastEventId = nil
local webhookSent = false

-- Функция проверки события (ТОЛЬКО ОДИН РАЗ!)
local function checkForEvent(webhookUrl)
    local success, result = pcall(function()
        if debugMode then debugPrint("🔍 Checking for event...") end
        
        local notifications = LocalPlayer.PlayerGui:FindFirstChild("Notifications")
        if not notifications then
            if debugMode then debugPrint("❌ Notifications folder not found") end
            return false, nil
        end
        
        local holder = notifications:FindFirstChild("holder")
        if not holder then
            if debugMode then debugPrint("❌ Holder not found in Notifications") end
            return false, nil
        end
        
        -- Ищем фрейм с нужным названием
        for _, frame in pairs(holder:GetChildren()) do
            if frame:IsA("Frame") then
                local frameName = frame.Name
                
                if debugMode then 
                    debugPrint("🔍 Found frame with name:", frameName)
                end
                
                if frameName == "A World Event is starting. Head to the Morioh Train Station to participate." then
                    -- Возвращаем true и ID фрейма (чтобы отличать разные события)
                    return true, frame
                end
            end
        end
        
        return false, nil
    end)
    
    if success then
        local eventExists, eventFrame = result
        
        if eventExists then
            -- Событие существует
            if not eventActive then
                -- Событие ТОЛЬКО ЧТО ПОЯВИЛОСЬ
                eventActive = true
                lastEventId = eventFrame
                webhookSent = false
                
                if debugMode then 
                    debugPrint("🎯 NEW EVENT DETECTED! Sending webhook...")
                end
                
                StatusLabel.Text = "Status: New event! Sending..."
                sendToDiscord(webhookUrl)
                webhookSent = true
                
            elseif eventActive and not webhookSent then
                -- Страховка: если событие активно, но вебхук не отправлен
                if debugMode then debugPrint("⚠️ Event active but webhook not sent - sending now...") end
                sendToDiscord(webhookUrl)
                webhookSent = true
                
            else
                -- Событие уже активно и вебхук отправлен - ничего не делаем
                if debugMode and math.random(1, 10) == 1 then -- Редко выводим, чтобы не спамить в консоль
                    debugPrint("⏳ Event still active - waiting for it to end...")
                end
            end
        else
            -- События нет
            if eventActive then
                -- Событие ТОЛЬКО ЧТО ЗАКОНЧИЛОСЬ
                eventActive = false
                lastEventId = nil
                webhookSent = false
                
                if debugMode then 
                    debugPrint("✅ Event ended - ready for next event")
                end
                StatusLabel.Text = "Status: Event ended - waiting for next..."
            end
        end
    elseif debugMode then
        debugPrint("❌ Error in checkForEvent:", result)
    end
end

-- Tracking variables
local isRunning = false
local loopConnection = nil
local checkCount = 0

-- Start tracking function
local function startTracking()
    local webhookUrl = WebhookBox.Text
    if webhookUrl == "" then
        StatusLabel.Text = "Status: Enter webhook URL!"
        if debugMode then debugPrint("Error: No webhook URL provided") end
        return
    end
    
    -- Сбрасываем состояние при старте
    eventActive = false
    lastEventId = nil
    webhookSent = false
    checkCount = 0
    
    isRunning = true
    ToggleButton.Text = "Stop Tracking"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 70, 70)
    StatusLabel.Text = "Status: Tracking active..."
    
    if debugMode then 
        debugPrint("🚀 Tracking started with webhook:", webhookUrl)
        debugPrint("📋 Anti-spam protection enabled - will send ONLY ONCE per event")
    end
    
    -- Start checking loop every second
    loopConnection = RunService.Heartbeat:Connect(function()
        if isRunning then
            task.wait(1)
            checkCount = checkCount + 1
            
            -- Показываем статус каждые 10 проверок
            if debugMode and checkCount % 10 == 0 then
                local status = eventActive and "ACTIVE" or "WAITING"
                local webhookStatus = webhookSent and "✅ Sent" or "⏳ Not sent"
                debugPrint(string.format("📊 Check #%d - Event: %s | Webhook: %s", 
                    checkCount, status, webhookStatus))
            end
            
            checkForEvent(WebhookBox.Text)
        end
    end)
end

-- Stop tracking function
local function stopTracking()
    isRunning = false
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    ToggleButton.Text = "Start Tracking"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(70, 130, 200)
    StatusLabel.Text = "Status: Stopped"
    
    if debugMode then 
        debugPrint("🛑 Tracking stopped. Total checks performed:", checkCount)
        debugPrint("Final state - Event:", eventActive and "ACTIVE" or "INACTIVE", 
                  "| Webhook sent:", webhookSent and "YES" or "NO")
    end
    
    -- Сбрасываем состояние
    eventActive = false
    lastEventId = nil
    webhookSent = false
end

-- Button click handler
ToggleButton.MouseButton1Click:Connect(function()
    if isRunning then
        stopTracking()
    else
        startTracking()
    end
end)

