local function updateSelectedStandsDisplay()
    local names={}
    for name,_ in pairs(selectedStands) do
        table.insert(names,name)
    end
    if #names==0 then
        selectedStandsLabel.Text="📋 Selected stands: None"
        selectedStandsLabel.TextColor3=colors.textDim
    else
        table.sort(names)
        selectedStandsLabel.Text="📋 Selected stands: "..table.concat(names,", ")
        selectedStandsLabel.TextColor3=colors.text
    end
end

