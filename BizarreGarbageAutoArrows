-- Функция получения данных с поддержкой скинов
local function gData()
    local pd=p:FindFirstChild("PlayerData") 
    if not pd then return "No","No","No" end
    
    local sd=pd:FindFirstChild("SlotData") 
    if not sd then return "No","No","No" end
    
    local st=sd:FindFirstChild("Stand")
    local sn,tn="???","???"
    
    if st and st.Value then
        local v=tostring(st.Value)
        
        local success, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(v)
        end)
        
        if success and data then
            if data.Skin and data.Skin ~= "" then
                sn = data.Skin
            else
                sn = data.Name or "???"
            end
            tn = data.Trait or "???"
        else
            sn = string.match(v,'"Name":"([^"]+)"') or "???"
            tn = string.match(v,'"Trait":"([^"]+)"') or "???"
            
            local skin = string.match(v,'"Skin":"([^"]+)"')
            if skin and skin ~= "" then
                sn = skin
            end
        end
    end
    
    local w=sd:FindFirstChild("Worthiness")
    return sn, tn, w and tostring(w.Value) or "???"
end

local function updateUI()
    local s,t,w=gData()
    sl.Text="Stand: "..s
    tl.Text="Trait: "..t
    wl.Text="Worth: "..w
    return s,t,w
end

-- Проверка условий остановки
local function checkStop()
    local s,t,w=updateUI()
    local wn=tonumber(w)
    
    -- Shiny всегда останавливает если включен
    if shiny and wn~=nil and wn==0 then
        return true
    end
    
    -- Проверка есть ли вообще выбранные условия
    local hasStandConditions = false
    for name,_ in pairs(selectedStands) do
        if name ~= "None" then
            hasStandConditions = true
            break
        end
    end
    
    local hasTraitConditions = false
    for name,_ in pairs(selectedTraits) do
        if name ~= "None" then
            hasTraitConditions = true
            break
        end
    end
    
    -- Если ничего не выбрано - не останавливаемся
    if not hasStandConditions and not hasTraitConditions then
        return false
    end
    
    -- Проверка стенда
    local standMatch = not hasStandConditions
    if hasStandConditions then
        for name,_ in pairs(selectedStands) do
            if s==name then
                standMatch = true
                break
            end
        end
    end
    
    -- Проверка трейта
    local traitMatch = not hasTraitConditions
    if hasTraitConditions then
        for name,_ in pairs(selectedTraits) do
            if t==name then
                traitMatch = true
                break
            end
        end
    end
    
    -- Применяем приоритет
    if currentPriority=="both" then
        return standMatch and traitMatch
    elseif currentPriority=="trait" then
        return traitMatch
    elseif currentPriority=="stand" then
        return standMatch
    elseif currentPriority=="either" then
        return standMatch or traitMatch
    end
    
    return false
end

