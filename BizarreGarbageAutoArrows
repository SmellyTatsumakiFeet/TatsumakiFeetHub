-- Функция получения данных
local function gData()
    local pd=p:FindFirstChild("PlayerData") 
    if not pd then return "No","No","No",false,"" end
    
    local sd=pd:FindFirstChild("SlotData") 
    if not sd then return "No","No","No",false,"" end
    
    local st=sd:FindFirstChild("Stand")
    local sn,tn="???","???"
    local hasSkin=false
    local skinValue=""
    
    if st and st.Value then
        local v=tostring(st.Value)
        
        local success, data = pcall(function()
            return http:JSONDecode(v)
        end)
        
        if success and data then
            if data.Skin and data.Skin ~= "" then
                sn = data.Skin
                hasSkin=true
                skinValue = data.Skin
            else
                sn = data.Name or "???"
            end
            tn = data.Trait or "???"
        else
            local name = string.match(v,'"Name":"([^"]+)"') or "???"
            local trait = string.match(v,'"Trait":"([^"]+)"') or "???"
            local skin = string.match(v,'"Skin":"([^"]+)"')
            
            if skin and skin ~= "" then
                sn = skin
                hasSkin=true
                skinValue = skin
            else
                sn = name
            end
            tn = trait
        end
    end
    
    local w=sd:FindFirstChild("Worthiness")
    return sn, tn, w and tostring(w.Value) or "???", hasSkin, skinValue
end

local function updateUI()
    local s,t,w,hasSkin,skinValue=gData()
    sl.Text="Stand: "..s
    tl.Text="Trait: "..t
    wl.Text="Worth: "..w
    return s,t,w,hasSkin,skinValue
end

-- Проверка условий остановки
local function checkStop()
    local s,t,w,hasSkin,skinValue=updateUI()
    local wn=tonumber(w)
    
    -- Shiny всегда останавливает если включен
    if shiny and wn~=nil and wn==0 then
        return true, "✨ SHINY"
    end
    
    -- Проверка есть ли вообще выбранные условия
    local hasStandConditions = false
    for name,_ in pairs(selectedStands) do
        if name ~= "None" then
            hasStandConditions = true
            break
        end
    end
    
    local hasTraitConditions = false
    for name,_ in pairs(selectedTraits) do
        if name ~= "None" then
            hasTraitConditions = true
            break
        end
    end
    
    local hasSkinConditions = false
    for name,_ in pairs(selectedSkins) do
        if name ~= "None" then
            hasSkinConditions = true
            break
        end
    end
    
    -- Проверка скина
    local skinMatch = false
    local matchedSkinName = ""
    if hasSkinConditions and hasSkin then
        for name,_ in pairs(selectedSkins) do
            if s == name then
                skinMatch = true
                matchedSkinName = name
                break
            end
        end
    end
    
    -- Проверка стенда
    local standMatch = false
    local matchedStandName = ""
    if hasStandConditions then
        for name,_ in pairs(selectedStands) do
            if s == name then
                standMatch = true
                matchedStandName = name
                break
            end
        end
    end
    
    -- Проверка трейта
    local traitMatch = false
    local matchedTraitName = ""
    if hasTraitConditions then
        for name,_ in pairs(selectedTraits) do
            if t == name then
                traitMatch = true
                matchedTraitName = name
                break
            end
        end
    end
    
    -- Если ничего не выбрано - не останавливаемся
    if not hasStandConditions and not hasTraitConditions and not hasSkinConditions then
        return false, ""
    end
    
    -- Применяем приоритеты
    local shouldStop = false
    local reason = ""
    
    if currentPriority=="skin" then
        shouldStop = skinMatch
        reason = "🎨 " .. matchedSkinName
    elseif currentPriority=="skinOrEither" then
        shouldStop = skinMatch or standMatch or traitMatch
        if skinMatch then
            reason = "🎨 " .. matchedSkinName
        elseif standMatch then
            reason = "📌 " .. matchedStandName
        elseif traitMatch then
            reason = "✨ " .. matchedTraitName
        end
    elseif currentPriority=="both" then
        shouldStop = standMatch and traitMatch
        if shouldStop then
            reason = "📌 " .. matchedStandName .. " + ✨ " .. matchedTraitName
        end
    elseif currentPriority=="trait" then
        shouldStop = traitMatch
        reason = "✨ " .. matchedTraitName
    elseif currentPriority=="stand" then
        shouldStop = standMatch
        reason = "📌 " .. matchedStandName
    elseif currentPriority=="either" then
        shouldStop = standMatch or traitMatch
        if standMatch then
            reason = "📌 " .. matchedStandName
        elseif traitMatch then
            reason = "✨ " .. matchedTraitName
        end
    end
    
    return shouldStop, reason
end

