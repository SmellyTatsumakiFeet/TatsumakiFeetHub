-- Обновляем данные при изменении значений
local function setupDataListener()
    local playerData = player:FindFirstChild("PlayerData")
    if not playerData then
        player.ChildAdded:Connect(function(child)
            if child.Name == "PlayerData" then
                task.wait(0.5)
                setupDataListener()
                updateData()
            end
        end)
        return
    end
    
    local slotData = playerData:FindFirstChild("SlotData")
    if not slotData then
        playerData.ChildAdded:Connect(function(child)
            if child.Name == "SlotData" then
                task.wait(0.5)
                setupDataListener()
                updateData()
            end
        end)
        return
    end
    
    local stand = slotData:FindFirstChild("Stand")
    if stand then
        stand.Changed:Connect(function()
            task.wait(0.1)
            updateData()
        end)
    else
        slotData.ChildAdded:Connect(function(child)
            if child.Name == "Stand" then
                task.wait(0.1)
                child.Changed:Connect(function()
                    task.wait(0.1)
                    updateData()
                end)
                updateData()
            end
        end)
    end
    
    local worthiness = slotData:FindFirstChild("Worthiness")
    if worthiness then
        worthiness.Changed:Connect(function()
            task.wait(0.1)
            updateData()
        end)
    else
        slotData.ChildAdded:Connect(function(child)
            if child.Name == "Worthiness" then
                task.wait(0.1)
                child.Changed:Connect(function()
                    task.wait(0.1)
                    updateData()
                end)
                updateData()
            end
        end)
    end
end

