-- Функция отправки в Discord
local function sendToDiscord(message)
    if webhookUrl == nil or webhookUrl == "" then
        return false
    end
    
    -- Проверяем, что это похоже на Discord webhook
    if not string.find(webhookUrl, "discord.com/api/webhooks/") then
        return false
    end
    
    local success, result = pcall(function()
        -- Создаем данные для отправки
        local data = {
            ["content"] = message,
            ["username"] = "Stand Farm Bot"
        }
        
        -- Конвертируем в JSON
        local jsonData = http:JSONEncode(data)
        
        -- Отправляем запрос
        request = syn and syn.request or http and http.request
        if request then
            request({
                Url = webhookUrl,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = jsonData
            })
            return true
        end
        return false
    end)
    
    return success
end

