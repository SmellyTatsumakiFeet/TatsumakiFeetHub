-- ОСНОВНОЕ ИЗМЕНЕНИЕ: функция получения данных с поддержкой скинов
local function gData()
    local pd=p:FindFirstChild("PlayerData") 
    if not pd then return "No","No","No" end
    
    local sd=pd:FindFirstChild("SlotData") 
    if not sd then return "No","No","No" end
    
    local st=sd:FindFirstChild("Stand")
    local sn,tn="???","???"
    
    if st and st.Value then
        local v=tostring(st.Value)
        
        -- Пробуем распарсить как JSON
        local success, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(v)
        end)
        
        if success and data then
            -- Если есть Skin, показываем его вместо Name
            if data.Skin and data.Skin ~= "" then
                sn = data.Skin
            else
                sn = data.Name or "???"
            end
            tn = data.Trait or "???"
        else
            -- Если не JSON, пробуем через регулярные выражения
            sn = string.match(v,'"Name":"([^"]+)"') or "???"
            tn = string.match(v,'"Trait":"([^"]+)"') or "???"
            
            -- Проверяем наличие Skin
            local skin = string.match(v,'"Skin":"([^"]+)"')
            if skin and skin ~= "" then
                sn = skin
            end
        end
    end
    
    local w=sd:FindFirstChild("Worthiness")
    return sn, tn, w and tostring(w.Value) or "???"
end

local function updateUI()
    local s,t,w=gData()
    sl.Text="Stand: "..s
    tl.Text="Trait: "..t
    wl.Text="Worth: "..w
    return s,t,w
end

local function checkStop()
    local s,t,w=updateUI()
    local wn=tonumber(w)
    
    -- Shiny останавливает АВТОМАТИЧЕСКИ только если включен чекбокс
    if shiny and wn~=nil and wn==0 then
        return true
    end
    
    -- Проверка стенда и трейта
    local sc=dStand=="" or s==dStand
    local tc=dTrait=="" or t==dTrait
    
    return (dStand~="" or dTrait~="") and sc and tc
end

local function updateStatus()
    if target then 
        if shiny and tonumber(wl.Text:match("%d+"))==0 then
            st.Text="Status: SHINY FOUND! (can force start)"
        else
            st.Text="Status: TARGET REACHED"
        end
        st.TextColor3=Color3.fromRGB(0,255,0)
    elseif farming then 
        st.Text="Status: FARMING..." 
        st.TextColor3=Color3.fromRGB(255,255,0)
    else 
        st.Text="Status: Idle" 
        st.TextColor3=Color3.fromRGB(150,150,150) 
    end
end

local function useArrow()
    local r=rs:FindFirstChild("requests") if not r then return end
    local c=r:FindFirstChild("character") if not c then return end
    local u=c:FindFirstChild("use_item") if u then u:FireServer("Stand Arrow") end
end

