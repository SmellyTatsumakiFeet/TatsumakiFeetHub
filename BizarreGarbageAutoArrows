end)

local last=0
rs2.Heartbeat:Connect(function()
    -- Автоматическая остановка только если не в принудительном режиме
    if checkStop() and farming and not target then
        target=true 
        farming=false
        tb.BackgroundColor3=Color3.fromRGB(255,0,0) 
        tb.Text="START"
        updateStatus()
    end
    
    -- Использование стрел если farming включен
    if farming then
        local n=tick()
        if n-last>=1 then 
            useArrow() 
            last=n 
        end
    end
end)

