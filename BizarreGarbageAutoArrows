-- Функция использования стрелы
local function useArrow()
    local args = {"Stand Arrow"}
    local useItem = replicatedStorage:FindFirstChild("requests"):FindFirstChild("character"):FindFirstChild("use_item")
    if useItem then
        useItem:FireServer(unpack(args))
    end
end

-- Функция обновления данных
local function updateData()
    local success, standResult, worthinessResult = pcall(function()
        local playerData = player:FindFirstChild("PlayerData")
        if not playerData then 
            return "No Data", "No Data"
        end
        
        local slotData = playerData:FindFirstChild("SlotData")
        if not slotData then 
            return "No Data", "No Data"
        end
        
        local stand = slotData:FindFirstChild("Stand")
        local standValue = "???"
        if stand then
            local value = stand.Value
            if type(value) == "string" then
                local pattern = '"Name":"([^"]+)"'
                local _, _, extracted = string.find(value, pattern)
                if extracted then
                    standValue = extracted
                else
                    standValue = "???"
                end
            else
                standValue = "???"
            end
        end
        
        local worthiness = slotData:FindFirstChild("Worthiness")
        local worthinessValue = "???"
        if worthiness then
            worthinessValue = tostring(worthiness.Value)
        end
        
        return standValue, worthinessValue
    end)
    
    if success then
        if standValueLabel then
            standValueLabel.Text = standResult or "???"
        end
        if worthinessValueLabel then
            worthinessValueLabel.Text = worthinessResult or "???"
        end
        
        -- Проверка Worthiness = 0
        local worthinessNum = tonumber(worthinessResult)
        local worthinessZero = (worthinessNum == 0)
        
        -- Проверяем совпадение с желаемым стендом
        if desiredStand ~= "" and standResult == desiredStand then
            if not autoStopEnabled then
                autoStopEnabled = true
                isActive = false
                toggleButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                toggleButton.Text = "OFF"
                autoStopStatus.Text = "✅ Target acquired! Auto-stop enabled"
                autoStopStatus.TextColor3 = Color3.fromRGB(0, 255, 0)
            end
        -- НОВОЕ: Проверка Worthiness = 0 если галочка включена
        elseif stopOnZeroWorthiness and worthinessZero and desiredStand ~= "" then
            if not autoStopEnabled then
                autoStopEnabled = true
                isActive = false
                toggleButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                toggleButton.Text = "OFF"
                autoStopStatus.Text = "⛔ Worthiness reached 0! Auto-stop enabled"
                autoStopStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
            end
        else
            if autoStopEnabled then
                autoStopEnabled = false
                autoStopStatus.Text = "⏸ Idle"
                autoStopStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
        end
    end
end

